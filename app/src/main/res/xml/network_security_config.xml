<?xml version="1.0" encoding="utf-8"?>
<!--
  Cahier des charges / correctif : panels IPTV en HTTP simple (non chiffré) refusés
  par défaut par Android 9+ (targetSdk 28+), qui bloque le cleartext traffic sauf
  déclaration explicite. Certains panels utilisent aussi des certificats HTTPS
  auto-signés ou installés manuellement par l'utilisateur (non reconnus par les
  CA système par défaut) : d'où le <certificates src="user">.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
