<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- §2.1 du cahier des charges : permissions déclarées dès le squelette -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        L'app doit fonctionner aussi bien sur téléphone/tablette (tactile) que sur
        boîtier Android TV (D-pad, pas forcément d'écran tactile) : aucune des deux
        fonctionnalités n'est donc "required" au sens du Play Store / du système.
    -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".DpFlixApplication"
        android:label="DP-Flix"
        android:allowBackup="true"
        android:banner="@drawable/tv_banner"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round">
        <!--
            §7 étape 2c-1 du cahier des charges : adaptive icon mobile (mipmap-anydpi-v26,
            API 26+, avec fallback vecteur combiné mipmap-anydpi pour API 23-25) et
            banner TV définitif (320x180dp), remplaçant les placeholders de l'étape 2b.
        -->

        <!-- Point d'entrée MOBILE (téléphone / tablette, tactile) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DpFlix">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Point d'entrée TV (boîtier Android TV, télécommande / D-pad) -->
        <activity
            android:name=".tv.TvMainActivity"
            android:exported="true"
            android:banner="@drawable/tv_banner"
            android:theme="@style/Theme.DpFlix">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
